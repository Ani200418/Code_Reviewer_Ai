# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Node Environment
NODE_ENV=development
PORT=5000

# Client URL for CORS
CLIENT_URL=http://localhost:3000

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ============================================
# AI SERVICE CONFIGURATION
# At least ONE of these API keys must be set
# ============================================

# Groq API (Primary - Fast & Free tier available)
# Get key from: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini API (Secondary - Free tier available)
# Get key from: https://ai.google.dev
GOOGLE_API_KEY=AIzaSy...

# Mistral API (Tertiary - Free tier available)
# Get key from: https://console.mistral.ai
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-small
